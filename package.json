{
  "name": "webprog-eloadas-beadando",
  "version": "1.0.0",
  "description": "Ez a projekt a **Web-programozás 1** kurzus keretében készült féléves beadandó feladat.",
  "main": "index.js",
  "workspaces": [
    "react-projects"
  ],
  "scripts": {
    "install-all": "npm install && npm install --prefix react-projects && npm install --prefix react",
    "setup-db": "C:/xampp/php/php.exe server/shared-db/db-config.php",
    "build:react": "npm run build --prefix react",
    "build:projects": "npm run build --prefix react-projects",
    "build": "npm run build:react && npm run build:projects",
    "start": "npm run dev --prefix react-projects && npm run dev --prefix react",
    "preview": "npm run preview --prefix react-projects",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sollabong/webprog-eloadas-beadando.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/sollabong/webprog-eloadas-beadando/issues"
  },
  "homepage": "https://github.com/sollabong/webprog-eloadas-beadando#readme",
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1"
  }
}
